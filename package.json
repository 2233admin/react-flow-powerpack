{
  "name": "react-flow-powerpack",
  "version": "0.1.0",
  "description": "A React Flow workflow IDE prototype for canonical workflow graphs, package internals, promoted parameters, and n8n JSON translation.",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/2233admin/react-flow-powerpack.git"
  },
  "bugs": {
    "url": "https://github.com/2233admin/react-flow-powerpack/issues"
  },
  "homepage": "https://github.com/2233admin/react-flow-powerpack#readme",
  "packageManager": "npm@11.16.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "node scripts/clean.mjs .next dist",
    "clean:dev": "node scripts/clean.mjs .next",
    "clean:dist": "node scripts/clean.mjs dist",
    "dev": "next dev --port 8080 --hostname 0.0.0.0",
    "prebuild": "node scripts/clean.mjs dist",
    "build": "next build",
    "build:dev": "next build",
    "build:verify": "next build && node scripts/smoke-test.mjs",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck",
    "check": "npm run typecheck && npm test && npm run build:verify",
    "test": "vitest run",
    "test:watch": "vitest",
    "agent:self-check": "node scripts/agent-self-check.mjs",
    "smoke": "node scripts/smoke-test.mjs",
    "smoke:visual": "node scripts/smoke-visual.mjs",
    "health-check": "node scripts/health-check.mjs"
  },
  "dependencies": {
    "@ai-sdk/react": "^4.0.15",
    "@base-ui/react": "^1.5.0",
    "@vercel/analytics": "1.6.1",
    "@xyflow/react": "^12.11.1",
    "ai": "^7.0.14",
    "animejs": "^4.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-force": "^3.0.0",
    "d3-hierarchy": "^3.1.2",
    "dagre": "^0.8.5",
    "elkjs": "^0.11.1",
    "gsap": "^3.15.0",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.16.0",
    "lz-string": "^1.5.0",
    "nanoid": "^5.1.16",
    "next": "16.2.6",
    "perfect-freehand": "^1.2.3",
    "react": "^19",
    "react-dom": "^19",
    "shadcn": "^4.8.0",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0",
    "y-protocols": "^1.0.7",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.31",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.0",
    "@types/d3-force": "^3.0.10",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/dagre": "^0.7.54",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "playwright": "^1.61.1",
    "postcss": "^8.5",
    "tailwindcss": "^4.2.0",
    "typescript": "5.7.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "hono": "4.12.25"
  }
}
